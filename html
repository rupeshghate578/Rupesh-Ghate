<template>
  <div class="container">
    <h1>To-Do List</h1>

    <div class="input-section">
      <input 
        type="text" 
        placeholder="Enter task..." 
        value={taskInput}
        onkeydown={handleKeyDown}
        onchange={handleInput}
      />

      <select onchange={handlePriorityChange}>
        <option value="Low">Low</option>
        <option value="Medium">Medium</option>
        <option value="High">High</option>
      </select>

      <button onclick={addTask}>Add</button>
    </div>

    <div class="filters">
      <button onclick={showAll}>All</button>
      <button onclick={showPending}>Pending</button>
      <button onclick={showCompleted}>Completed</button>
    </div>

    <template for:each={filteredTasks} for:item="task">
      <div key={task.id} class={taskClass}>
        <span>{task.text}</span>
        <span class="priority">{task.priority}</span>

        <button onclick={toggleTask} data-id={task.id}>✔</button>
        <button onclick={deleteTask} data-id={task.id}>✖</button>
      </div>
    </template>
  </div>
</template>
